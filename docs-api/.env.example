# --- docs-api environment ---
# Copy to .env for local development: cp .env.example .env

# development | test | production
ENVIRONMENT=development

# Port the API listens on (Railway injects PORT in production)
PORT=8080

# Postgres connection string.
# Matches docker-compose.dev.yml (host port 5433 -> container 5432).
DATABASE_URL=postgres://postgres:postgres@localhost:5433/docs

# Secret used to sign JWT access tokens (min 16 chars). CHANGE IN PRODUCTION.
JWT_SECRET=dev-secret-change-me-in-production-please

# Access-token lifetime in seconds (default 7 days). No refresh rotation by design.
JWT_ACCESS_TOKEN_TTL_SECONDS=604800

# Origin allowed by CORS (the docs-web app). Used only when the browser calls the API cross-origin.
FRONTEND_ORIGIN=http://localhost:3000

# Optional cookie domain (leave blank for host-only cookies; the recommended setup).
COOKIE_DOMAIN=
